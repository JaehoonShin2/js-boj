const fs = require('fs');
const input = fs.readFileSync('dev/stdin')
.toString().split('\n');
const T = Number(input[0]);
let answer = ''
for(let i = 1; i<=T; i++){
    let tem = input[i].split(' ');
    let num1 = parseInt(tem[0]);
    let num2 = parseInt(tem[1]);
    answer += 'Case #'+i+': '+num1+' + '+num2+' = '+(num1+num2)+'\n';
}
console.log(answer)
